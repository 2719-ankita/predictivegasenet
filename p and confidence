    )

    gbc_scores.append(
        accuracy_score(y_test,pred_gbc)
    )

# =====================================================
# Confidence Interval Function
# =====================================================

def compute_ci(values):

    mean = np.mean(values)

    sem = np.std(values, ddof=1) / np.sqrt(len(values))

    ci = t.ppf(0.975, len(values)-1) * sem

    return mean, mean-ci, mean+ci

# =====================================================
# GASENet Confidence Interval
# =====================================================

mean_acc, lower_acc, upper_acc = compute_ci(gasenet_scores)

print("Accuracy Mean :", round(mean_acc*100,2))
print("95% CI :", 
      f"[{lower_acc*100:.2f}, {upper_acc*100:.2f}]")

# =====================================================
# Paired t-tests
# =====================================================

print("\nP VALUES")

print(
    "GASENet vs SVC:",
    ttest_rel(gasenet_scores, svc_scores).pvalue
)

print(
    "GASENet vs MLP:",
    ttest_rel(gasenet_scores, mlp_scores).pvalue
)

print(
    "GASENet vs RFC:",
    ttest_rel(gasenet_scores, rfc_scores).pvalue
)

print(
    "GASENet vs XGB:",
    ttest_rel(gasenet_scores, xgb_scores).pvalue
)

print(
    "GASENet vs GBC:",
    ttest_rel(gasenet_scores, gbc_scores).pvalue
)
