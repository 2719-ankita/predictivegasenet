# =====================================================
# Statistical Validation of GASENet
# =====================================================

import numpy as np
import pandas as pd

from sklearn.model_selection import RepeatedStratifiedKFold
from sklearn.metrics import accuracy_score
from scipy.stats import ttest_rel, t

# =====================================================
# Define Repeated CV
# =====================================================

cv = RepeatedStratifiedKFold(
    n_splits=10,
    n_repeats=10,
    random_state=42
)

# =====================================================
# Storage
# =====================================================

gasenet_scores = []
svc_scores = []
mlp_scores = []
rfc_scores = []
xgb_scores = []
gbc_scores = []

# =====================================================
# Cross Validation
# =====================================================

